{
    "name": "davidt-de/kirby-uniform-mosparo",
    "description": "Mosparo spam protection for Kirby Uniform forms",
    "type": "kirby-plugin",
    "version": "1.0.0",
    "license": "MIT",
    "homepage": "https://github.com/davidt-de/kirby-uniform-mosparo",
    "keywords": [
        "kirby",
        "uniform",
        "mosparo",
        "spam-protection",
        "captcha",
        "gdpr"
    ],
    "authors": [
        {
            "name": "Patrick Davidt",
            "email": "hallo@davidt.de"
        }
    ],
    "require": {
        "php": ">=8.0",
        "mzur/kirby-uniform": "^5.0",
        "mosparo/php-api-client": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Uniform\\Mosparo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Uniform\\Mosparo\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml",
        "test-coverage": "phpunit --configuration phpunit.xml --coverage-html tests/coverage"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "installer-name": "uniform-mosparo"
    },
    "config": {
        "allow-plugins": {
            "getkirby/composer-installer": true
        }
    }
}
